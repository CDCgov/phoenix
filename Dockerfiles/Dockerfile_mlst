FROM ubuntu:focal AS app 
ARG MLST_VER="2.25.0" 
ARG ANY2FASTA_VER="0.4.2" 

LABEL base.image="ubuntu:focal" 
LABEL dockerfile.version="2" 
LABEL software="mlst" 
LABEL software.version="${MLST_VER}" 
LABEL description="Scan contig files against PubMLST typing schemes" 
LABEL website="https://github.com/tseemann/mlst" 
LABEL license="https://github.com/tseemann/mlst/blob/master/LICENSE" 
LABEL maintainer="Jill Hagey" 
LABEL maintainer.email="qpk9@cdc.gov"
LABEL maintainer="Nick Vlachos" 
LABEL maintainer.email="nvx4@cdc.gov"

# Install dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \ 
  wget \ 
  ca-certificates \ 
  perl \ 
  libmoo-perl \ 
  liblist-moreutils-perl \ 
  libjson-perl \ 
  gzip \ 
  file \ 
  ncbi-blast+ && \ 
  apt-get autoclean && rm -rf /var/lib/apt/lists/*

# Install any2fasta
RUN wget https://github.com/tseemann/any2fasta/archive/refs/tags/v${ANY2FASTA_VER}.tar.gz && \ 
  tar xzf v${ANY2FASTA_VER}.tar.gz && \ 
  rm v${ANY2FASTA_VER}.tar.gz && \ 
  chmod +x any2fasta-${ANY2FASTA_VER}/any2fasta && \ 
  mv -v any2fasta-${ANY2FASTA_VER}/any2fasta /usr/local/bin

# Install mlst
RUN wget https://github.com/tseemann/mlst/archive/v${MLST_VER}.tar.gz && \ 
  tar -xzf v${MLST_VER}.tar.gz && \ 
  rm v${MLST_VER}.tar.gz

# Set PATH and locale
ENV PATH="/mlst-${MLST_VER}/bin:${PATH}" \ LC_ALL=C.UTF-8

# Remove default database
RUN rm -rf /mlst-${MLST_VER}/db

# Copy custom database (ensure this runs every time, no caching)
COPY --chown=root:root db /mlst-${MLST_VER}/db

# Set proper permissions on database
RUN chmod -R 755 /mlst-${MLST_VER}/db && \ 
  find /mlst-${MLST_VER}/db -type f -exec chmod 644 {} \; && \ 
  find /mlst-${MLST_VER}/db -type d -exec chmod 755 {} \; && \
  mv /mlst-${MLST_VER}/db/scheme_species_map.tsv /mlst-${MLST_VER}/db/scheme_species_map.tab

# Verify installation and show database info
RUN echo "=== MLST Installation Info ===" && \ 
  which mlst && \ 
  mlst --version && \ 
  echo "=== Database location ===" && \ 
  ls -la /mlst-${MLST_VER}/db/ && \ 
  echo "=== Available schemes ===" && \ 
  mlst --list && \ 
  echo "=== Dependency check ===" && \ 
  mlst --check

# Create /data directory for working
RUN mkdir -p /data && chmod 777 /data

# Set working directory
WORKDIR /data

# Default command
CMD ["mlst", "--help"]